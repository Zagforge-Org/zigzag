	path = ast/grammars/tree-sitter-zig
	url = https://github.com/tree-sitter-grammars/tree-sitter-zig
[submodule "ast/grammars/tree-sitter-typescript"]
	path = ast/grammars/tree-sitter-typescript
	url = https://github.com/tree-sitter/tree-sitter-typescript
[submodule "ast/grammars/tree-sitter-rust"]
	path = ast/grammars/tree-sitter-rust
	url = https://github.com/tree-sitter/tree-sitter-rust
[submodule "ast/grammars/tree-sitter-go"]
	path = ast/grammars/tree-sitter-go
